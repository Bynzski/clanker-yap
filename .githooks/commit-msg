#!/usr/bin/env sh
set -eu

msg_file="$1"
first_line=$(head -n 1 "$msg_file" | tr -d '\r')

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

cat <<'EOF'
Invalid commit message.

Use Conventional Commits:
  <type>[optional scope]: <description>

Examples:
  fix: handle empty push-to-talk capture
  docs(release): add 0.1.0 AppImage release procedure
  feat(settings): add cumulative word count
EOF

exit 1
