{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clanker Yap",
  "version": "0.1.3",
  "identifier": "dev.jay.voice-transcribe",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": null,
    "beforeBuildCommand": null
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": true,
    "windows": [{
      "label": "main",
      "title": "Clanker Yap",
      "width": 480,
      "height": 196,
      "resizable": false,
      "decorations": false,
      "center": true
    }],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis", "msi"],
    "macOS": {
      "entitlements": "./entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
